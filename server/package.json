{
  "name": "lextrack-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "seed": "node seed.js",
    "schema": "node schema.js",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --migration-file-language js",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --migration-file-language js",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language js",
    "test": "jest --forceExit --detectOpenHandles --runInBand",
    "backfill:embeddings": "node scripts/backfill-embeddings.js"
  },
  "dependencies": {
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.0",
    "mailparser": "^3.9.3",
    "node-pg-migrate": "^8.0.4",
    "otplib": "^13.3.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
