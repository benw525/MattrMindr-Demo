# ── Core ──────────────────────────────────────────────
NODE_ENV=production

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mattrmindr
# DB_SSL=require          # "require" | "verify" | "false" (default: require in prod)

# ── Session / Auth ────────────────────────────────────
SESSION_SECRET=generate-a-random-64-char-hex-string
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# ── Application URL ──────────────────────────────────
APP_URL=https://YOUR_DOMAIN.com

# ── Reverse Proxy ─────────────────────────────────────
TRUST_PROXY=1
# CORS_ORIGIN=https://YOUR_DOMAIN.com    # only needed if frontend is on a separate domain

# ── SendGrid (Email) ─────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Twilio (SMS) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── Field Encryption ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required for encrypting SSNs, tokens, and MFA secrets at rest
# FIELD_ENCRYPTION_KEY=your-64-char-hex-string

# ── Google Gemini (OCR) ──────────────────────────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXX

# ── Cloudflare R2 (File Storage) ─────────────────────
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=mattrmindr-files
