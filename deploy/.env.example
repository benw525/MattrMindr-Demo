# ══════════════════════════════════════════════════════
# MattrMindr — Environment Variables
# ══════════════════════════════════════════════════════
#
# IMPORTANT: If a value contains special characters (& ! $ # spaces),
# wrap it in single quotes:
#   ONLYOFFICE_PASSWORD='Kizzie&Ben6615'
#
# Copy this file to .env in the project root and fill in all values.
# The server loads .env automatically via dotenv — no need to source it.
# ══════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────
NODE_ENV=production

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mattrmindr
# DB_SSL=require          # "require" | "verify" | "false" (default: require in prod)

# ── Session / Auth ────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=generate-a-random-64-char-hex-string
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# ── Application URL ──────────────────────────────────
APP_URL=https://YOUR_DOMAIN.com

# ── Reverse Proxy ─────────────────────────────────────
TRUST_PROXY=1
# CORS_ORIGIN=https://YOUR_DOMAIN.com    # only needed if frontend is on a separate domain
# EXTERNAL_CORS_ORIGINS=https://other-app.example.com  # comma-separated, for external API consumers

# ── SendGrid (Email) ─────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Twilio (SMS) ──────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── Field Encryption ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required for encrypting SSNs, tokens, and MFA secrets at rest
# FIELD_ENCRYPTION_KEY=your-64-char-hex-string

# ── Google Gemini (OCR) ──────────────────────────────
# GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXX

# ── ONLYOFFICE DocSpace (Document Editing) ───────────
# ONLYOFFICE_URL=https://your-docspace.onlyoffice.com
# ONLYOFFICE_USER=admin@example.com
# ONLYOFFICE_PASSWORD='your-password'
# ONLYOFFICE_ROOM_ID=1234567

# ── AWS S3 (File Storage) ────────────────────────────
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=mattrmindr-files
# AWS_REGION=us-east-1
# S3_ENDPOINT=                           # optional, for S3-compatible services

# ── Cloudflare R2 (File Storage, alternative to S3) ──
# R2 vars take priority over AWS S3 if both are set
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=mattrmindr-files
