modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["poppler", "unzip", "ffmpeg"]

[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "javascript_openai_ai_integrations:2.0.0", "sendgrid:1.0.0", "twilio:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production node server/index.js"]
build = ["bash", "build.sh"]

[userenv]

[userenv.shared]
ONLYOFFICE_URL = "https://docspace-13tl7v.onlyoffice.com"
ONLYOFFICE_USER = "beemer@quarkgames.com"
ONLYOFFICE_ROOM_ID = "2853087"
