{
  "name": "lextrack-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm start --prefix server\" \"cross-env PORT=5000 DANGEROUSLY_DISABLE_HOST_CHECK=true npm start --prefix lextrack\"",
    "seed": "npm run seed --prefix server",
    "schema": "npm run schema --prefix server",
    "build": "cd lextrack && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "docx": "^9.6.0",
    "docxtemplater": "^3.68.2",
    "drizzle-zod": "^0.8.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "openai": "^6.24.0",
    "otplib": "^13.3.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.17.2",
    "pizzip": "^3.2.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.19",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.12.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  }
}
